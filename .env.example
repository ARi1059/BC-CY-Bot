# BC-CY-Bot 环境变量模板
# 复制为 .env 后填入真实值；.env 已在 .gitignore 中排除。

# === 必填 ===

# Telegram Bot Token (从 @BotFather 获取)
BOT_TOKEN=

# 数据库连接串
# 生产: postgresql+asyncpg://user:pass@host:5432/dbname
# 开发: sqlite+aiosqlite:///./bccy_bot.db
DATABASE_URL=sqlite+aiosqlite:///./bccy_bot.db

# 初始超级管理员 Telegram 数字 ID
# - 首次启动时写入 admins 表
# - 后续启动若该 ID 与数据库中的超级管理员不一致，自动覆盖（原超级管理员降级为副管理员）
# - 应急换人：直接修改此值并重启即可
INITIAL_SUPER_ADMIN_ID=

# === 可选 ===

# 日志级别 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# 时区（影响日志/卡片时间显示）
TIMEZONE=Asia/Shanghai

# === Docker Compose 用 ===

# Postgres 密码（仅 docker-compose 启动 postgres 服务时使用）
POSTGRES_PASSWORD=bccy
