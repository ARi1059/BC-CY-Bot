# BC-CY-Bot 环境变量模板
# 复制为 .env 后填入真实值；.env 已在 .gitignore 中排除。

# === 必填 ===

# Telegram Bot Token (从 @BotFather 获取)
BOT_TOKEN=

# 数据库连接串
# 生产 (原生 PostgreSQL): postgresql+asyncpg://bccy:强密码@127.0.0.1:5432/bccy
# 开发 (SQLite 单文件):    sqlite+aiosqlite:///./bccy_bot.db
DATABASE_URL=postgresql+asyncpg://bccy:CHANGE_ME@127.0.0.1:5432/bccy

# 初始超级管理员 Telegram 数字 ID
# - 首次启动时写入 admins 表
# - 后续启动若该 ID 与数据库中的超级管理员不一致，自动覆盖（原超级管理员降级为副管理员）
# - 应急换人：直接修改此值并重启即可
INITIAL_SUPER_ADMIN_ID=

# === 可选 ===

# 日志级别 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# 时区（影响日志/卡片时间显示）
TIMEZONE=Asia/Shanghai
